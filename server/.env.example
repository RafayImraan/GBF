PORT=4000
HEDERA_NETWORK=testnet
GBF_ENABLE_MAINNET=false

# Primary Hedera operator used by the API layer
HEDERA_OPERATOR_ID=0.0.123456
HEDERA_OPERATOR_KEY=302e020100300506032b657004220420REPLACE_WITH_OPERATOR_KEY
HEDERA_TREASURY_ACCOUNT_ID=0.0.123456
HEDERA_GUARDIAN_POLICY_ID=guardian-policy-gbf-demo

# Signing mode
HEDERA_ENABLE_LIVE_SIGNING=true
HEDERA_SIGNER_MODE=remote

# Remote signer connection
HEDERA_REMOTE_SIGNER_URL=http://gbf.railway.internal:8787
HEDERA_REMOTE_SIGNER_TOKEN=replace-with-shared-signer-token
HEDERA_REMOTE_SIGNER_PORT=8787
HEDERA_REMOTE_SIGNER_BIND=0.0.0.0

# Signer-held Hedera credentials
HEDERA_SIGNER_OPERATOR_ID=0.0.123456
HEDERA_SIGNER_OPERATOR_KEY=302e020100300506032b657004220420REPLACE_WITH_SIGNER_KEY
HEDERA_SIGNER_TREASURY_ACCOUNT_ID=0.0.123456

# Admin account
GBF_ADMIN_EMAIL=admin@gbf.local
GBF_ADMIN_PASSWORD=ChangeMe123!
GBF_ADMIN_NAME=GBF Admin
GBF_SESSION_TTL_HOURS=12

# Web/API runtime
GBF_CORS_ORIGIN=http://localhost:5173
GBF_BODY_LIMIT=1mb
GBF_TRUST_PROXY=true
GBF_METRICS_ENABLED=true
